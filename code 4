    "<br><p><b>Notes Trades:</b></p>" & _
    Build_Trade_Bullets(ws)

End Function

'====================================================
' TRADE BULLETS
'====================================================

Function Build_Trade_Bullets(ws As Worksheet) As String

    Dim html As String

    html = "<ul>"

    Dim lastTradeCol As Long
    Dim c As Long

    lastTradeCol = ws.Cells(TRADE_HEADER_ROW, ws.Columns.Count).End(xlToLeft).Column

    For c = FIRST_TRADE_COLUMN To lastTradeCol

        html = html & "<li>"

        html = html & Get_Value(ws, c, "TOTAL_RETURN_PAYER")

        html = html & " buys "

        html = html & Get_Value(ws, c, "ORIGINAL_NOTIONAL_AMOUNT")

        html = html & " of "

        html = html & Get_Value(ws, c, "REFERENCE_OBLIGATION")

        html = html & " from "

        html = html & Get_Value(ws, c, "TOTAL_RETURN_RECEIVER")

        html = html & ".</li>"

    Next c

    html = html & "</ul>"

    Build_Trade_Bullets = html

End Function

'====================================================
' BUILD TRS TABLE
'====================================================

Function Build_TRS_Table(ws As Worksheet, emailType As String) As String

    Dim visibilityColumn As Long

    If emailType = "CLIENT" Then
        visibilityColumn = CLIENT_VISIBILITY_COLUMN
    Else
        visibilityColumn = BOOKING_VISIBILITY_COLUMN
    End If

    Dim html As String

    html = "<table border='1' cellspacing='0' cellpadding='4' style='border-collapse:collapse;font-family:Calibri;font-size:11pt;'>"

    Dim lastTradeCol As Long
    Dim lastRow As Long

    lastTradeCol = ws.Cells(TRADE_HEADER_ROW, ws.Columns.Count).End(xlToLeft).Column

    lastRow = ws.Cells(ws.Rows.Count, VARIABLE_COLUMN).End(xlUp).Row

    Dim r As Long
    Dim c As Long

    html = html & "<tr style='background-color:#1F1F4E;color:white;'>"

    html = html & "<th></th>"

    For c = FIRST_TRADE_COLUMN To lastTradeCol

        html = html & "<th>" & ws.Cells(TRADE_HEADER_ROW, c).Value & "</th>"

    Next c

    html = html & "</tr>"

    For r = VARIABLE_START_ROW To lastRow

        Dim visibilityValue As String

        visibilityValue = UCase(Trim(ws.Cells(r, visibilityColumn).Value))

        If visibilityValue = "Y" Then

            html = html & "<tr>"

            html = html & "<td><b>" & _
            Format_Label(ws.Cells(r, VARIABLE_COLUMN).Value) & _
            "</b></td>"

            For c = FIRST_TRADE_COLUMN To lastTradeCol

                html = html & "<td>" & ws.Cells(r, c).Value & "</td>"

            Next c

            html = html & "</tr>"

        End If

    Next r

    html = html & "</table>"

    Build_TRS_Table = html

End Function

'====================================================
' GET VALUE
'====================================================

Function Get_Value(ws As Worksheet, tradeCol As Long, variableName As String) As String

    Dim lastRow As Long
    Dim r As Long

    lastRow = ws.Cells(ws.Rows.Count, VARIABLE_COLUMN).End(xlUp).Row

    For r = VARIABLE_START_ROW To lastRow

        If Trim(ws.Cells(r, VARIABLE_COLUMN).Value) = variableName Then

            Get_Value = Trim(ws.Cells(r, tradeCol).Value)

            Exit Function

        End If

    Next r

    Get_Value = ""

End Function

'====================================================
' CLEAN FILE NAME
'====================================================

Function Clean_File_Name(fileName As String) As String

    fileName = Replace(fileName, "/", "-")
    fileName = Replace(fileName, "\", "-")
    fileName = Replace(fileName, ":", "-")
    fileName = Replace(fileName, "*", "")
    fileName = Replace(fileName, "?", "")
    fileName = Replace(fileName, Chr(34), "")
    fileName = Replace(fileName, "<", "")
    fileName = Replace(fileName, ">", "")
    fileName = Replace(fileName, "|", "")

    Clean_File_Name = fileName

End Function

'====================================================
' FORMAT LABEL
'====================================================

Function Format_Label(txt As String) As String

    txt = Replace(txt, "_", " ")

    Format_Label = WorksheetFunction.Proper(txt)

End Function