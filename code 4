Option Explicit

Const TRADE_HEADER_ROW As Long = 10
Const VARIABLE_START_ROW As Long = 11

Const VARIABLE_COLUMN As Long = 1
Const CLIENT_VISIBILITY_COLUMN As Long = 2
Const BOOKING_VISIBILITY_COLUMN As Long = 3

Const FIRST_TRADE_COLUMN As Long = 4

Const OUTPUT_PATH As String = "D:\TRS_Project\Output\"

'====================================================
' UPDATE TRADE COLUMNS
'====================================================

Sub Update_Trade_Columns()

    Dim ws As Worksheet
    Set ws = Sheets("MAIN")

    Dim tradeCount As Long
    tradeCount = ws.Range("B6").Value

    Dim c As Long

    ' CLEAR OLD HEADERS
    For c = FIRST_TRADE_COLUMN To 50

        ws.Cells(TRADE_HEADER_ROW, c).ClearContents

    Next c

    ' CREATE NEW HEADERS
    For c = FIRST_TRADE_COLUMN To FIRST_TRADE_COLUMN + tradeCount - 1

        ws.Cells(TRADE_HEADER_ROW, c).Value = "TRS Trade " & (c - 3)

    Next c

    MsgBox "Trade Columns Updated"

End Sub

'====================================================
' GENERATE TS DOCUMENTS
'====================================================

Sub Generate_TS_Documents()

    Application.ScreenUpdating = False

    Dim wsMain As Worksheet
    Dim wsTemplate As Worksheet

    Set wsMain = Sheets("MAIN")
    Set wsTemplate = Sheets("TS_TEMPLATE")

    Dim lastTradeCol As Long
    Dim tradeCol As Long

    lastTradeCol = wsMain.Cells(TRADE_HEADER_ROW, wsMain.Columns.Count).End(xlToLeft).Column

    For tradeCol = FIRST_TRADE_COLUMN To lastTradeCol

        If Trim(wsMain.Cells(TRADE_HEADER_ROW, tradeCol).Value) <> "" Then

            Generate_Single_TS wsMain, wsTemplate, tradeCol

        End If

    Next tradeCol

    Application.ScreenUpdating = True

    MsgBox "TS Documents Generated"

End Sub

'====================================================
' GENERATE SINGLE TS
'====================================================

Sub Generate_Single_TS(wsMain As Worksheet, wsTemplate As Worksheet, tradeCol As Long)

    Dim wdApp As Object
    Dim wdDoc As Object

    Set wdApp = CreateObject("Word.Application")

    wdApp.Visible = False

    Set wdDoc = wdApp.Documents.Add

    Dim tempSheet As Worksheet

    wsTemplate.Copy After:=wsTemplate

    Set tempSheet = ActiveSheet

    tempSheet.Name = "TEMP_TS_" & tradeCol

    Dim usedRange As Range
    Set usedRange = tempSheet.UsedRange

    Dim cell As Range

    For Each cell In usedRange

        If InStr(cell.Value, "<<") > 0 Then

            Dim variableName As String

            variableName = Replace(cell.Value, "<<", "")
            variableName = Replace(variableName, ">>", "")

            cell.Value = Get_Value(wsMain, tradeCol, variableName)

        End If

    Next cell

    usedRange.Copy

    wdDoc.Content.PasteExcelTable False, False, False

    Dim receiver As String
    Dim entity As String

    receiver = Clean_File_Name(Get_Value(wsMain, tradeCol, "TOTAL_RETURN_RECEIVER"))

    entity = Clean_File_Name(Get_Value(wsMain, tradeCol, "REFERENCE_ENTITY"))

    Dim docPath As String

    docPath = OUTPUT_PATH & receiver & " - " & entity & ".docx"

    wdDoc.SaveAs2 docPath

    wdDoc.Close False

    wdApp.Quit

    Application.DisplayAlerts = False

    tempSheet.Delete

    Application.DisplayAlerts = True

End Sub

'====================================================
' CLIENT EMAIL
'====================================================

Sub Generate_Client_Email()

    Dim ws As Worksheet
    Set ws = Sheets("MAIN")

    Dim outlookApp As Object
    Dim outlookMail As Object

    Set outlookApp = CreateObject("Outlook.Application")

    Set outlookMail = outlookApp.CreateItem(0)

    outlookMail.To = ws.Range("B2").Value
    outlookMail.CC = ws.Range("B3").Value

    outlookMail.Subject = Build_Email_Subject(ws)

    outlookMail.HTMLBody = Build_Client_HTML(ws)

    outlookMail.Display

End Sub

'====================================================
' BOOKING EMAIL
'====================================================

Sub Generate_Booking_Email()

    Dim ws As Worksheet
    Set ws = Sheets("MAIN")

    Dim outlookApp As Object
    Dim outlookMail As Object

    Set outlookApp = CreateObject("Outlook.Application")

    Set outlookMail = outlookApp.CreateItem(0)

    outlookMail.To = ws.Range("B4").Value
    outlookMail.CC = ws.Range("B5").Value

    outlookMail.Subject = "Booking - " & Build_Email_Subject(ws)

    outlookMail.HTMLBody = Build_Booking_HTML(ws)

