'====================================================
' TRADE SECTION
'====================================================

Function Build_Trade_Section(ws As Worksheet) As String

    Dim tradeType As String

    tradeType = ws.Range("B5").Value

    Select Case tradeType

        Case "Bond Trade"
            Build_Trade_Section = Build_Bond_Trades(ws)

        Case "Loan Trade"
            Build_Trade_Section = Build_Loan_Trades(ws)

        Case "Notes Trade"
            Build_Trade_Section = Build_Notes_Trades(ws)

        Case Else
            Build_Trade_Section = ""

    End Select

End Function

'====================================================
' BOND TRADES
'====================================================

Function Build_Bond_Trades(ws As Worksheet) As String

    Build_Bond_Trades = _
    "<br><p><b>Bond Trades:</b></p>" & _
    Build_Trade_Bullets(ws)

End Function

