End Sub

'====================================================
' EMAIL SUBJECT
'====================================================

Function Build_Email_Subject(ws As Worksheet) As String

    Build_Email_Subject = _
    "Barclays / " & _
    Get_Value(ws, FIRST_TRADE_COLUMN, "TOTAL_RETURN_RECEIVER") & _
    " - " & _
    Get_Value(ws, FIRST_TRADE_COLUMN, "REFERENCE_ENTITY") & _
    " - TRS Recap"

End Function

'====================================================
' CLIENT EMAIL HTML
'====================================================

Function Build_Client_HTML(ws As Worksheet) As String

    Dim html As String

    html = "<html><body style='font-family:Calibri;font-size:11pt;'>"

    html = html & "<p>Team,</p>"

    html = html & "<p>Please find below the TRS recap.</p>"

    html = html & Build_TRS_Table(ws, "CLIENT")

    html = html & Build_Trade_Section(ws)

    html = html & "<br><p>Thank you,</p>"

    html = html & "</body></html>"

    Build_Client_HTML = html

End Function

'====================================================
' BOOKING EMAIL HTML
'====================================================

Function Build_Booking_HTML(ws As Worksheet) As String

    Dim html As String

    html = "<html><body style='font-family:Calibri;font-size:11pt;'>"

    html = html & "<p>Team,</p>"

    html = html & "<p>Please find below the booking recap.</p>"

    html = html & Build_TRS_Table(ws, "BOOKING")

